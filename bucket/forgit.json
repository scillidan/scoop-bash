{
    "version": "26.05.0",
    "description": "A utility tool powered by fzf for using git interactively.",
    "homepage": "https://github.com/wfxr/forgit",
    "license": "MIT",
    "notes": "Run with bash.exe. Recommend installing main/git then adding $env:SCOOP\\apps\\git\\current\\bin, $env:SCOOP\\apps\\git\\current\\usr\\bin to the top of the system environment's PATH.",
    "architecture": {
        "64bit": {
            "url": "https://github.com/wfxr/forgit/releases/download/26.05.0/forgit-26.05.0.tar.gz",
            "hash": "15b5c23db79dda43c315405f90a95ad4f88eae89de00173ea84164da0702cdad"
        }
    },
    "extract_dir": "bin",
    "pre_install": [
        "New-Item -Path \"$dir\\forgit.cmd\" -ItemType File -Force",
        "Add-Content -Path \"$dir\\forgit.cmd\" -Value \"bash $env:SCOOP\\apps\\forgit\\current\\git-forgit %*\""
    ],
    "bin": "forgit.cmd",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/wfxr/forgit/releases/download/$version/forgit-$version.tar.gz"
            }
        }
    }
}
