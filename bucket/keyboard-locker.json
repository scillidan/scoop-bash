{
    "version": "1.0",
    "description": "AutoHotkey script to temporarily lock your keyboard.",
    "homepage": "https://github.com/sophice/ahk-keyboard-locker",
    "license": "GPL-3.0-or-later",
    "notes": "Configuration file (settings.ini) is auto-generated on first run",
    "architecture": {
        "64bit": {
            "url": "https://github.com/sophice/ahk-keyboard-locker/releases/download/v1.0/keyboard-locker.exe",
            "hash": "038D09B82E63A52608A342A697C50254C71AB8DBEEF3BDB5A4E1E15DB5673D94"
        }
    },
    "pre_install": "New-Item \"$dir\\settings.ini\" -ItemType File -Force | Out-Null",
    "post_install": [
        "$dirpath = $dir.Replace('\\', '\\\\')",
        "'add-startup.reg', 'remove-startup.reg' | ForEach-Object {",
        "    if (Test-Path \"$bucketsdir\\shovel\\scripts\\$app\\$_\") {",
        "        $content = Get-Content \"$bucketsdir\\shovel\\scripts\\$app\\$_\"",
        "        $content = $content.Replace('$dir', $dirpath)",
        "        if ($global) { $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE') }",
        "        $content | Set-Content -Path \"$dir\\$_\"",
        "    }",
        "}"
    ],
    "post_uninstall": [
        "if (Test-Path \"$dir\\remove-startup.reg\") { reg import \"$dir\\remove-startup.reg\" }"
    ],
    "shortcuts": [
        [
            "keyboard-locker.exe",
            "Keyboard Locker"
        ]
    ],
    "persist": "settings.ini",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/sophice/ahk-keyboard-locker/releases/download/v$version/keyboard-locker.exe"
            }
        }
    }
}
